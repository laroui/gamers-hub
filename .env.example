# ============================================================
#  GAMERS HUB — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to git
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────
# Docker Compose default — change for production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gamers_hub
POSTGRES_USER=gamers_hub
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://gamers_hub:changeme_in_production@localhost:5432/gamers_hub

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_random_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_byte_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── MinIO (self-hosted object storage for cover art cache) ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_changeme
MINIO_BUCKET_COVERS=game-covers

# ── IGDB (free — requires Twitch dev account) ────────────────
# Register at: https://dev.twitch.tv/console
# Create an app → get Client ID + Secret
# IGDB access is free, no rate limit for reasonable usage
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# ── SteamGridDB (free — custom cover art community) ──────────
# Register at: https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=your_steamgriddb_key_here

# ── Steam Web API (free) ─────────────────────────────────────
# Get key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# ── Xbox Live / Microsoft (free Azure App Registration) ──────
# Register at: https://portal.azure.com → App Registrations
# Add redirect URI: http://localhost:3000/api/v1/auth/oauth/xbox/callback
XBOX_CLIENT_ID=your_azure_app_client_id
XBOX_CLIENT_SECRET=your_azure_app_client_secret
XBOX_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/xbox/callback

# ── PlayStation Network (free developer account) ─────────────
# Register at: https://partners.api.playstation.com
PSN_CLIENT_ID=your_psn_client_id
PSN_CLIENT_SECRET=your_psn_client_secret
PSN_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/psn/callback

# ── Epic Games (free developer account) ──────────────────────
# Register at: https://dev.epicgames.com/portal
EPIC_CLIENT_ID=your_epic_client_id
EPIC_CLIENT_SECRET=your_epic_client_secret
EPIC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/epic/callback

# ── GOG (free developer program) ─────────────────────────────
# Register at: https://www.gog.com/devportal
GOG_CLIENT_ID=your_gog_client_id
GOG_CLIENT_SECRET=your_gog_client_secret
GOG_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/gog/callback

# ── Nintendo Switch Online (unofficial — session token) ───────
# Obtained via nxapi — see SETUP.md for instructions
NINTENDO_SESSION_TOKEN=your_nintendo_session_token_here

# ── EA App (free OAuth) ───────────────────────────────────────
# Register at: https://developer.ea.com
EA_CLIENT_ID=your_ea_client_id
EA_CLIENT_SECRET=your_ea_client_secret
EA_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/ea/callback

# ── Ubisoft Connect (free OAuth) ─────────────────────────────
# Register at: https://developers.ubisoft.com
UBISOFT_CLIENT_ID=your_ubisoft_client_id
UBISOFT_CLIENT_SECRET=your_ubisoft_client_secret
UBISOFT_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/ubisoft/callback

# ── Battle.net (free Blizzard developer account) ─────────────
# Register at: https://develop.battle.net/access/clients
BATTLENET_CLIENT_ID=your_battlenet_client_id
BATTLENET_CLIENT_SECRET=your_battlenet_client_secret
BATTLENET_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/battlenet/callback
BATTLENET_REGION=eu

# ── BullMQ / Worker ───────────────────────────────────────────
WORKER_CONCURRENCY=3
SYNC_JOB_TIMEOUT_MS=120000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60000

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
